# =================================================================
# DockShield DaaS — Environment Variables
# =================================================================
# Copy to .env.local for local dev, or set in Vercel Dashboard
# for production deployment.
# =================================================================

# --- Vercel Frontend (public/client-safe) ---
CESIUM_ION_TOKEN=your_cesium_ion_token
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key

# --- Supabase Edge Functions (secrets — set via CLI) ---
# supabase secrets set STRIPE_SECRET_KEY=sk_live_...
# supabase secrets set STRIPE_WEBHOOK_SECRET=whsec_...
# supabase secrets set RESEND_API_KEY=re_...
# supabase secrets set APP_DOMAIN=https://dockshield.vercel.app
#
# SUPABASE_URL and SUPABASE_SERVICE_ROLE_KEY are auto-injected
# into Edge Functions by Supabase — no manual config needed.
